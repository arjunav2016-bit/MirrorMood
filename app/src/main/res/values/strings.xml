    <string name="privacy_title">Privacy</string>
    <string name="privacy_headline">Your privacy, our absolute priority.</string>
    <string name="privacy_summary">At MirrorMood, your emotional archive stays personal. Reflection data never leaves your device unless you explicitly choose to share it.</string>
    <string name="privacy_current_status_title">Current Device Status</string>
    <string name="privacy_current_status_summary">Live indicators update whenever you return from Android permission settings.</string>
    <string name="privacy_on_device_title">100% on-device processing</string>
    <string name="privacy_on_device_summary">Every expression is analyzed directly on your hardware. No facial data is uploaded to external servers.</string>
    <string name="privacy_camera_title">Camera privacy</string>
    <string name="privacy_camera_summary">Real-time analysis only. MirrorMood never saves raw video or still images.</string>
    <string name="privacy_storage_title">Local storage</string>
    <string name="privacy_storage_summary">Your journal and mood history stay in your phone\'s secure local database.</string>
    <string name="privacy_cloud_sync_title">No cloud sync</string>
    <string name="privacy_cloud_sync_summary">We intentionally keep the archive offline-first. If your data is gone with the device, it was never exposed to someone else\'s server.</string>
    <string name="privacy_mirror_promise_title">The Mirror Promise</string>
    <string name="privacy_mirror_promise_summary">You own your data. You own your feelings. Mood vectors exist only long enough to support the current reflection, then they are discarded.</string>
