<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Semi-transparent dark vignette overlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Scanning frame: rounded-corner border with inner padding -->
    <item
        android:left="28dp"
        android:top="28dp"
        android:right="28dp"
        android:bottom="28dp">
        <shape android:shape="rectangle">
            <stroke android:width="2.5dp" android:color="#8878A0E8" />
            <corners android:radius="16dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Inner glow frame (tighter, softer) -->
    <item
        android:left="30dp"
        android:top="30dp"
        android:right="30dp"
        android:bottom="30dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#3378A0E8" />
            <corners android:radius="14dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

</layer-list>
