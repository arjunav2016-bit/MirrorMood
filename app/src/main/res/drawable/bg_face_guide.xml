<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Semi-transparent dark vignette overlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Scanning frame: rounded-corner border with inner padding -->
    <item
        android:left="28dp"
        android:top="28dp"
        android:right="28dp"
        android:bottom="28dp">
        <shape android:shape="rectangle">
            <stroke android:width="2.5dp" android:color="#8878A0E8" />
            <corners android:radius="16dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Inner glow frame (tighter, softer) -->
    <item
        android:left="30dp"
        android:top="30dp"
        android:right="30dp"
        android:bottom="30dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#3378A0E8" />
            <corners android:radius="14dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Corner bracket: top-left -->
    <item
        android:left="20dp"
        android:top="20dp"
        android:right="260dp"
        android:bottom="260dp">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#A59DC1F4" />
            <corners
                android:topLeftRadius="14dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Corner bracket: top-right -->
    <item
        android:left="260dp"
        android:top="20dp"
        android:right="20dp"
        android:bottom="260dp">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#A59DC1F4" />
            <corners
                android:topLeftRadius="0dp"
                android:topRightRadius="14dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Corner bracket: bottom-left -->
    <item
        android:left="20dp"
        android:top="260dp"
        android:right="260dp"
        android:bottom="20dp">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#A59DC1F4" />
            <corners
                android:topLeftRadius="0dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="14dp"
                android:bottomRightRadius="0dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Corner bracket: bottom-right -->
    <item
        android:left="260dp"
        android:top="260dp"
        android:right="20dp"
        android:bottom="20dp">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#A59DC1F4" />
            <corners
                android:topLeftRadius="0dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="14dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

</layer-list>
