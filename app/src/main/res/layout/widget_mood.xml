<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/tvWidgetEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🪞"
        android:textSize="40sp"/>

    <TextView
        android:id="@+id/tvWidgetMood"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap to open"
        android:textSize="14sp"
        android:textColor="@color/mm_on_surface"
        android:textStyle="bold"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvWidgetLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MirrorMood"
        android:textSize="10sp"
        android:textColor="@color/mm_on_surface_secondary"
        android:layout_marginTop="2dp"/>

</LinearLayout>
