<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/smartActionCard"
    style="@style/MM.Card.Hero"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:visibility="gone"
    tools:visibility="visible">

    <FrameLayout
        android:id="@+id/smartCardBackground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ═══ Breathe Mode UI ═══ -->
        <LinearLayout
            android:id="@+id/breatheContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvSmartBreatheEmoji"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_mood_orb"
                    android:gravity="center"
                    android:textSize="20sp"
                    tools:text="🫧" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSmartBreatheTitle"
                        style="?attr/textAppearanceTitleMedium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/colorOnSurface"
                        tools:text="Take a Breath" />

                    <TextView
                        android:id="@+id/tvSmartBreatheSubtitle"
                        style="?attr/textAppearanceBodySmall"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="Recenter your focus." />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/frameBreathingArea"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="16dp">

                <View
                    android:id="@+id/viewBreathingRing"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_breathing_ring" />

                <TextView
                    android:id="@+id/tvBreathingInstruction"
                    style="?attr/textAppearanceBodyMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="?attr/colorPrimaryDark"
                    android:text="Tap to Start" />

            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartBreathing"
                style="@style/MM.Button.Tonal"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Start 1-Min Pause" />

        </LinearLayout>

        <!-- ═══ Quote Mode UI ═══ -->
        <LinearLayout
            android:id="@+id/quoteContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvSmartQuoteLabel"
                style="?attr/textAppearanceLabelMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorPrimary"
                android:text="DAILY QUOTE" />

            <TextView
                android:id="@+id/tvSmartQuoteText"
                style="?attr/textAppearanceHeadlineSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="?attr/colorOnSurface"
                android:lineSpacingExtra="4dp"
                tools:text="&quot;Whatever you can do or dream you can, begin it.&quot;" />

            <TextView
                android:id="@+id/tvSmartQuoteAuthor"
                style="?attr/textAppearanceBodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="— Johann Wolfgang von Goethe" />

        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
