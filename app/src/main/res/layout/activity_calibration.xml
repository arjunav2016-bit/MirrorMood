<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical"
    android:paddingStart="32dp"
    android:paddingTop="20dp"
    android:paddingEnd="32dp"
    android:paddingBottom="28dp">

    <TextView
        style="@style/MM.Text.Headline.Medium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/calibration_title" />

    <TextView
        style="@style/MM.Text.Body.Large"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:text="@string/calibration_subtitle" />

    <com.google.android.material.card.MaterialCardView
        style="@style/MM.Card.Hero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="16dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="320dp">

            <androidx.camera.view.PreviewView
                android:id="@+id/previewView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:scaleType="fillCenter" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_face_guide" />

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressCalibration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:max="100"
        android:progress="0"
        app:indicatorColor="?attr/colorPrimary"
        app:trackColor="?attr/colorSurfaceContainerHighest"
        app:trackCornerRadius="4dp" />

    <TextView
        android:id="@+id/tvStatus"
        style="@style/MM.Text.Title.Medium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/calibration_seek_face" />

    <TextView
        android:id="@+id/tvHint"
        style="@style/MM.Text.Body.Medium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:text="@string/calibration_hint_center" />

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnComplete"
        style="@style/MM.Button.Filled"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:enabled="false"
        android:text="@string/calibration_complete" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSkip"
        style="@style/MM.Button.Text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/calibration_skip" />
</LinearLayout>
