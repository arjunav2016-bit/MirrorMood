<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/MM.Card.Filled"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Category Accent Bar -->
        <View
            android:id="@+id/viewAccentBar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_category_accent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <!-- Top row: Category chip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTipCategory"
                    style="?attr/textAppearanceLabelSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Breathing"
                    android:textColor="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/tvTipDuration"
                    style="?attr/textAppearanceLabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2-5 min"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Content row: Emoji + Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTipEmoji"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_mood_orb"
                    android:gravity="center"
                    android:text="🧘"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tvTipTitle"
                    style="?attr/textAppearanceTitleSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:text="Box Breathing" />
            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/tvTipDescription"
                style="?attr/textAppearanceBodySmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="2dp"
                android:text="Inhale for four counts, hold, then exhale with softness."
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
