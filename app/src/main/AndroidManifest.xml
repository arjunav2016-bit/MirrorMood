<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Check for Health Connect app -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <application
        android:name=".MirrorMoodApp"
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MirrorMood">

        <!-- Onboarding (Launcher) -->
        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:theme="@style/Theme.MirrorMood.Starting"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- Camera calibration (first-run) -->
        <activity
            android:name=".ui.calibration.CalibrationActivity"
            android:exported="false" />

        <!-- Lock Activity -->
        <activity
            android:name=".ui.lock.LockActivity"
            android:theme="@style/Theme.MirrorMood.Starting"
            android:exported="false" />

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:launchMode="singleTop"
            android:theme="@style/Theme.MirrorMood.Starting"
            android:exported="false" />

        <!-- Timeline Activity -->
        <activity
            android:name=".ui.timeline.TimelineActivity"
            android:launchMode="singleTop"
            android:exported="false" />
        <!-- Insights Activity -->
        <activity
            android:name=".ui.insights.InsightsActivity"
            android:launchMode="singleTop"
            android:exported="false" />
        <!-- History Activity -->
        <activity
            android:name=".ui.history.HistoryActivity"
            android:launchMode="singleTop"
            android:exported="false" />
        <!-- Correlations Activity -->
        <activity
            android:name=".ui.correlations.CorrelationsActivity"
            android:launchMode="singleTop"
            android:exported="false" />
        <!-- Privacy Activity -->
        <activity
            android:name=".ui.privacy.PrivacyActivity"
            android:launchMode="singleTop"
            android:exported="false" />
        <activity
            android:name=".ui.privacy.PrivacyReportActivity"
            android:launchMode="singleTop"
            android:exported="false" />
        <!-- Journal Activity -->
        <activity
            android:name=".ui.journal.JournalActivity"
            android:launchMode="singleTop"
            android:exported="false" />
        <!-- Recommendations Activity -->
        <activity
            android:name=".ui.recommendations.RecommendationsActivity"
            android:launchMode="singleTop"
            android:exported="false" />
        <!-- Settings Activity -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:launchMode="singleTop"
            android:exported="false" />
        <!-- Achievements Activity -->
        <activity
            android:name=".ui.achievements.AchievementsActivity"
            android:launchMode="singleTop"
            android:exported="false" />
        <!-- Guided Wellness Sessions -->
        <activity
            android:name=".ui.wellness.WellnessSessionActivity"
            android:launchMode="singleTop"
            android:exported="false" />
        <!-- Weekly Report -->
        <activity
            android:name=".ui.report.WeeklyReportActivity"
            android:launchMode="singleTop"
            android:exported="false" />
        <!-- Session History -->
        <activity
            android:name=".ui.wellness.SessionHistoryActivity"
            android:launchMode="singleTop"
            android:exported="false" />


        <!-- Background Mood Monitor Service -->
        <service
            android:name=".service.MoodMonitorService"
            android:foregroundServiceType="camera"
            android:exported="false" />

        <!-- Quick Settings Tile -->
        <service
            android:name=".service.MoodTileService"
            android:icon="@drawable/ic_journal"
            android:label="MirrorMood Tracking"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Mood Widget -->
        <receiver
            android:name=".widget.MoodWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/mood_widget_info"/>
        </receiver>

        <!-- FileProvider for CSV export sharing -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Disable default WorkManager initializer so HiltWorkerFactory can take over -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Wear OS Sync Service -->
        <service
            android:name=".wear.WearDataReceiverService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:host="*"
                    android:pathPrefix="/quick_log"
                    android:scheme="wear" />
            </intent-filter>
        </service>

    </application>

</manifest>

